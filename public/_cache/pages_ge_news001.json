[{"id":"3","idx":"1","cid":"0","date":"1504340572","nav_type":"0","type":"plugin","title":"მთავარი","description":"<p>შპს \"VIP Intellect Group\" გამორჩეული მრავალპროფილიანი სასწავლო ცენტრია საქართველოში, ჩვენი&nbsp;გუნდი უკვე&nbsp;21 წელია ატარებს ტრენინგებს სხვადასხვა მიმართულებით. უკვე ასობით ადგილობრივი თუ საერთაშორისო კომპანიის კადრი&nbsp;არის ჩვენი&nbsp;კურსდამთავრებული.<\/p>\n<p>ჩვენი მიზანია მივცეთ მსმენელებს პრაქტიკული უნარ-ჩვევები, რათა დამოუკიდებლად შეძლონ თავის დამკვიდრება სასურველ სფეროში!<\/p>\n<p>ჩვენთან მიღებული ცოდნის შედეგად კურსდამთავრებულები მნიშვნელოვნად აუმჯობესებენ საქმანობას სხვადასხვა სფეროში.<\/p>","text":"<p>მიზანი<\/p>","slug":"home","usefull_type":"","cssclass":"","redirect":"","lang":"ge","position":"1","visibility":"0","status":"0"},{"id":"60","idx":"7","cid":"0","date":"1523103835","nav_type":"0","type":"text","title":"ტრენინგები","description":"<p>ტრენინგები ტრენინგი სასწავლო ცენტრი ტრენინგ ცენტრი ტრენერი ტრენერები training centre<\/p>","text":"","slug":"trainings","usefull_type":"","cssclass":"","redirect":"","lang":"ge","position":"2","visibility":"0","status":"0"},{"id":"66","idx":"10","cid":"0","date":"1523105248","nav_type":"0","type":"text","title":"პროექტები","description":"<p>პროექტები<\/p>","text":"","slug":"projects","usefull_type":"","cssclass":"","redirect":"","lang":"ge","position":"3","visibility":"0","status":"0"},{"id":"74","idx":"14","cid":"0","date":"1523108012","nav_type":"0","type":"text","title":"კონსალტინგი","description":"<p>კონსალტინგი<\/p>","text":"","slug":"consulting","usefull_type":"","cssclass":"","redirect":"","lang":"ge","position":"4","visibility":"0","status":"0"},{"id":"80","idx":"17","cid":"0","date":"1523108415","nav_type":"0","type":"text","title":"სტაჟირება","description":"<p>სტაჟირება დასაქმება<\/p>","text":"","slug":"Internship","usefull_type":"","cssclass":"","redirect":"","lang":"ge","position":"5","visibility":"0","status":"0"},{"id":"84","idx":"19","cid":"0","date":"1523110201","nav_type":"