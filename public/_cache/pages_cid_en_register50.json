[{"id":"147","idx":"51","cid":"50","date":"1523701929","nav_type":"0","type":"text","title":"ჯანდაცვიც მენეჯმენტი","description":"","text":"<p>ჯანდაცვის მენეჯმენტის სასერთიფიკატო კურსი<\/p>","slug":"healths","usefull_type":"","cssclass":"","redirect":"","lang":"en","position":"1","visibility":"0","status":"0"},{"id":"153","idx":"54","cid":"50","date":"1523702279","nav_type":"0","type":"text","title":"ხარისხის კონტროლი","description":"","text":"<p>ხარისხის კონტროლი<\/p>","slug":"control","usefull_type":"","cssclass":"","redirect":"","lang":"en","position":"2","visibility":"0","status":"0"},{"id":"323","idx":"139","cid":"50","date":"1662376556","nav_type":"0","type":"text","title":"სამედიცინო წარმომადგენელი","description":"<p>სამედიცინო წარმომადგენლის მოსამზადებელი სასერთიფიკატო კურსი<\/p>","text":"<p>ტრენინგი განკუთვნილია უმაღლესი სამედიცინო განათლების მქონე პირებისთვის<br \/> <br \/>კურსის მიზანია: სამედიცინო წარმომადგენლების გადამზადება<\/p>\n<p>კურსი მოიცავს:<br \/>1 კომუნიკაციის საფუძვლები და ფსიქოლოგია, მოსმენა კომუნიკაციის ბარიერი <br \/>2 პიროვნების ფსიქოტიპები და თვისებები <br \/>3 კომუნიკაცია სხვა და სხვა ფსიქოტიპებთან <br \/>4 კომპეტენციის დონეები, პოტენციალი, ვიზიტის ეტაპები <br \/>5 ლოგიკური და მოტივირებული მოთხოვნები, პრეზენტაცია, შეთანხმება <br \/>6 სიტუაციური ამოცანები, ტესტირება<\/p>\n<p>კურსი მოიცავს: 6 ლექციას<br \/>კურსის ღირებულება: 250 ლარი<\/p>","slug":"health-medical representative","usefull_type":"","cssclass":"","redirect":"","lang":"en","position":"3","visibility":"0","status":"0"},{"id":"151","idx":"53","cid":"50","date":"1523702222","nav_type":"0","type":"text","title":"სამედიცინო რეგისტრატორის მოსამზადებელი კურსი","description":"","text":"<p>რეგისტრატორი<\/p>","slug":"registratory","usefull_type":"","cssclass":"","redirect":"","lang":"en","position":"4","visibility":"0","status":"0"},{"id":"149","idx":"52","cid":"50","date":"1523702159","nav_type":"0","type":"text","title":"ფარმაკოლოგიის კურსი","description":"","text":"<p>ფარმაკოლოგია<\/p>","slug":"farmacy","usefull_type":"","cssclass":"","redirect":"","lang":"en","position":"5","visibility":"0","status":"0"}]